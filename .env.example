# Kopiere diese Datei zu ".env.local" und trage die echten Werte ein.
# .env.local wird NICHT committet (steht in .gitignore).
# Die echten Werte findest du im jeweiligen Dashboard oder beim Team.

# --- Mapbox (Karte / Grundstücksauswahl) ---
# Öffentlicher Token, Dashboard: https://account.mapbox.com/access-tokens/
NEXT_PUBLIC_MAPBOX_TOKEN=

# --- Basis-URL der App ---
# Lokal: http://localhost:3000  |  Produktion: die echte Domain
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# --- Supabase (Datenbank) ---
# Dashboard: https://supabase.com/dashboard  ->  Project Settings -> API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# --- Stripe (Bezahlung) ---
# Dashboard: https://dashboard.stripe.com/apikeys  (Testschlüssel beginnt mit sk_test_)
STRIPE_SECRET_KEY=
# Stripe webhook signing secret (Dashboard -> Webhooks)
STRIPE_WEBHOOK_SECRET=

# --- Supabase (Server) ---
# Optional: Service Role Key für serverseitige Updates.
# Wenn leer, wird der normale ANON-Schlüssel verwendet.
SUPABASE_SERVICE_ROLE_KEY=

# --- Resend (Bestätigungs-E-Mails) ---
# Dashboard: https://resend.com/api-keys
RESEND_API_KEY=

# --- Google Ads Conversion-Tracking (optional, für Werbe-Erfolgsmessung) ---
# Google Ads -> Tools -> Conversions -> Website-Conversion erstellen -> Tag.
# ID-Format "AW-XXXXXXXXX"; Label ist der Teil nach dem "/" im send_to-Wert.
# Beide leer lassen = Tracking deaktiviert (kein Google-Tag wird geladen).
NEXT_PUBLIC_GOOGLE_ADS_ID=
NEXT_PUBLIC_GOOGLE_ADS_CONVERSION_LABEL=

# --- Google Analytics 4 (optional, Webanalyse) ---
# Analytics -> Verwaltung -> Datenstreams -> Web-Stream -> Mess-ID ("G-XXXXXXXXXX").
# Leer lassen = GA4 deaktiviert (kein Google-Tag für Analytics wird geladen).
NEXT_PUBLIC_GA_ID=
