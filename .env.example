# Kopiere diese Datei zu ".env.local" und trage die echten Werte ein.
# .env.local wird NICHT committet (steht in .gitignore).
# Die echten Werte findest du im jeweiligen Dashboard oder beim Team.

# --- Mapbox (Karte / Grundstücksauswahl) ---
# Öffentlicher Token, Dashboard: https://account.mapbox.com/access-tokens/
NEXT_PUBLIC_MAPBOX_TOKEN=

# --- Basis-URL der App ---
# Lokal: http://localhost:3000  |  Produktion: die echte Domain
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# --- Supabase (Datenbank) ---
# Dashboard: https://supabase.com/dashboard  ->  Project Settings -> API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# --- Stripe (Bezahlung) ---
# Dashboard: https://dashboard.stripe.com/apikeys  (Testschlüssel beginnt mit sk_test_)
STRIPE_SECRET_KEY=

# Signing-Secret aus dem Stripe-Dashboard:
# Developers -> Webhooks -> Endpoint anlegen
# URL:    https://<deine-domain>/api/stripe-webhook
# Events: checkout.session.completed
# Beginnt mit "whsec_".
STRIPE_WEBHOOK_SECRET=

# --- Resend (Bestätigungs-E-Mails) ---
# Dashboard: https://resend.com/api-keys
RESEND_API_KEY=

# Optional: Absender für die Auftragsbestätigung. Default ist die
# Resend-Sandbox-Adresse (onboarding@resend.dev). Für Produktion eine
# in Resend verifizierte Adresse eintragen, z. B.:
#   RESEND_FROM=Lota <noreply@lota-solutions.ch>
RESEND_FROM=

# Optional: Support-Mail für interne Fehlerbenachrichtigungen aus dem
# Stripe-Webhook (Default: info@lota-solutions.ch).
SUPPORT_EMAIL=

# --- Baupotential-Engine (Server-seitiger Aufruf nach Stripe-Erfolg) ---
# Läuft auf einem Infomaniak-VPS. Endpoint /analyse + /pdf sind mit
# X-API-Key geschützt; den Key findest du im Bitwarden ("Lota — Env Variablen").
ENGINE_API_URL=https://api.lota-solutions.ch
ENGINE_API_KEY=
