# Kopiere diese Datei zu ".env.local" und trage die echten Werte ein.
# .env.local wird NICHT committet (steht in .gitignore).
# Die echten Werte findest du im jeweiligen Dashboard oder beim Team.

# --- Mapbox (Karte / Grundstücksauswahl) ---
# Öffentlicher Token, Dashboard: https://account.mapbox.com/access-tokens/
NEXT_PUBLIC_MAPBOX_TOKEN=

# --- Basis-URL der App ---
# Lokal: http://localhost:3000  |  Produktion: die echte Domain
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# --- Supabase (Datenbank) ---
# Dashboard: https://supabase.com/dashboard  ->  Project Settings -> API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# --- Stripe (Bezahlung) ---
# Dashboard: https://dashboard.stripe.com/apikeys  (Testschlüssel beginnt mit sk_test_)
STRIPE_SECRET_KEY=

# --- Resend (Bestätigungs-E-Mails) ---
# Dashboard: https://resend.com/api-keys
RESEND_API_KEY=
